# Crashlytics generated files
crashlytics-build.properties

# Exclude generated Visual Studio cache
.vscode/

# DO NOT ignore assets or scenes
!Assets/
!ProjectSettings/
!Packages/

# Python backend
ai/backend/.venv/
ai/backend/__pycache__/
ai/backend/.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.env
*.env