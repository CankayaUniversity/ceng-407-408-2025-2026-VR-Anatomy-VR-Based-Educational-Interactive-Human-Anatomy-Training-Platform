--- !u!114 &1780208903
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1780208901}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "VR Anatomi, sa\u011Fl\u0131k meslek lisesi \xF6\u011Frencilerinin anatomi
    e\u011Fitimini daha anla\u015F\u0131l\u0131r, etkile\u015Fimli ve kal\u0131c\u0131
    hale getirmek amac\u0131yla geli\u015Ftirilmi\u015F bir sanal ger\xE7eklik uygulamas\u0131d\u0131r.
    Proje, \xF6\u011Frencilerin insan v\xFCcudunu \xFC\xE7 boyutlu ortamda incelemelerine,
    anatomik yap\u0131lar\u0131 daha kolay kavramalar\u0131na ve teorik bilgilerini
    g\xF6rsel deneyimle desteklemelerine yard\u0131mc\u0131 olmay\u0131 hedeflemektedir.\n\nUygulama
    i\xE7erisinde yer alan etkile\u015Fimli i\xE7erikler sayesinde kullan\u0131c\u0131lar
    farkl\u0131 anatomik yap\u0131lar\u0131 inceleyebilmekte, quiz sistemi ile \xF6\u011Frendikleri
    bilgileri test edebilmekte ve yapay zeka destekli konu\u015Fma \xF6zelli\u011Fi
    sayesinde kullan\u0131c\u0131lar, MEB m\xFCfredat\u0131na uygun olarak anatomi
    ve temel fizyoloji konular\u0131na dair sorular\u0131na anl\u0131k yan\u0131t
    alabilmektedir. Bu sayede \xF6\u011Frenme s\xFCrecinin daha aktif, verimli ve
    kullan\u0131c\u0131 odakl\u0131 hale getirilmesi ama\xE7lanm\u0131\u015Ft\u0131r.\n\nLokman
    Hekim Mesleki ve Teknik Anadolu Lisesi i\xE7in geli\u015Ftirilen bu proje, \xC7ankaya
    \xDCniversitesi Bilgisayar M\xFChendisli\u011Fi \xF6\u011Frencileri Kutay Ayo\u011Flu,
    Elifnaz Talas, \xC7a\u011Fla Pelin Do\u011Fan, \xD6yk\xFC \xC7oban ve Yaz\u0131l\u0131m
    M\xFChendisli\u011Fi \xF6\u011Frencisi Sena Akbaba taraf\u0131ndan hayata ge\xE7irilmi\u015Ftir.\n\nDan\u0131\u015Fmanl\u0131k
    s\xFCreci, \xC7ankaya \xDCniversitesi \xF6\u011Fretim \xFCyeleri Do\xE7. Dr.
    G\xFCl Tokdemir ve Dr. \xD6\u011Fr. \xDCyesi Talha Karadeniz ile Lokman Hekim
    Mesleki ve Teknik Anadolu Lisesi \xF6\u011Fretmeni \xD6zlem G\xF6kt\xFCrk rehberli\u011Finde
    y\xFCr\xFCt\xFClm\xFC\u015Ft\xFCr."
  m_isRightToLeft: 0
