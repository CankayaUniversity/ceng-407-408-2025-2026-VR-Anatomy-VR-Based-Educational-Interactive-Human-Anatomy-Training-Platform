  entries:
  - id: os_frontale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Frontale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; yass\u0131 kemik; al\u0131n"
    body: "Al\u0131n kemi\u011Fidir ve kafan\u0131n \xF6n \xFCst b\xF6l\xFCm\xFCnde
      bulunur. "
    steps: "[\"Do\u011Fumda iki par\xE7a halinde iken 5-6 ya\u015Flar\u0131nda kemikle\u015Ferek
      tek kemi\u011Fe d\xF6n\xFC\u015F\xFCr.\", \"Kafan\u0131n \xFCst b\xF6l\xFCm\xFCnde
      iki Os Parietale ile eklem yapar.\", \"Ka\u015F kemerleri ve orbitan\u0131n
      tavan\u0131n\u0131 olu\u015Fturur.\", \"Orbitan\u0131n \xFCst i\xE7 k\u0131sm\u0131nda
      2 adet sin\xFCs\xFC vard\u0131r.\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_occipitale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Occipitale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; yass\u0131 kemik; artkafa; foramen
      magnum"
    body: "Artkafa kemi\u011Fidir ve kafan\u0131n arka alt b\xF6l\xFCm\xFCnde yer
      al\u0131r."
    steps: "[\"Omurgan\u0131n ilk omuru ile eklem yapar.\", \"Kafatas\u0131 bo\u015Flu\u011Funun
      omurga kanal\u0131 ile ba\u011Flant\u0131s\u0131n\u0131 sa\u011Flayan foramen
      magnum bu kemik \xFCzerindedir.\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_sphenoidale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Sphenoidale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; d\xFCzensiz; temel; taban; sella turcica"
    body: "Temel kemiktir ve kafan\u0131n taban\u0131nda artkafa ve \u015Fakak kemi\u011Finin
      \xF6n\xFCnde yer al\u0131r."
    steps: "[\"B\xFCt\xFCn kafa kemikleri ve baz\u0131 y\xFCz kemikleri ile eklem
      yapar.\", \"G\xF6vdesinin \xFCst k\u0131sm\u0131ndaki sella turcica b\xF6l\xFCm\xFCne
      hipofiz bezi yerle\u015Fmi\u015Ftir.\", \"G\xF6vde k\u0131sm\u0131nda 2 adet
      sin\xFCs\xFC vard\u0131r.\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_ethmoidale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Ethmoidale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; d\xFCzensiz; kalbur; burun"
    body: "Kalbur kemi\u011Fidir ve os sphenoidale ile kafa taban\u0131n\u0131n \xF6n\xFCnde
      yer al\u0131r."
    steps: "[\"Burun b\xF6lmesinin \xFCst k\u0131sm\u0131n\u0131 olu\u015Fturur.\",
      \"Concha nasalis superior ve concha nasalis media bu kemi\u011Fin uzant\u0131s\u0131d\u0131r.\",
      \"2 adet sin\xFCs\xFC vard\u0131r.\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_parietale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Parietale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; yass\u0131 kemik; duvar; sutura sagittalis;
      \xE7ift"
    body: "Duvar kemiktir ve kafatas\u0131n\u0131n \xFCst yan duvar\u0131n\u0131
      olu\u015Fturur."
    steps: "[\"2 adet Os Parietale vard\u0131r.\", \"\u0130ki Os Parietale kafan\u0131n
      \xFCst b\xF6l\xFCm\xFCnde birbiriyle eklem yapar (sutura sagittalis).\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_temporale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Temporale
    topic: Movement System
    region: Head_Face
    tags: "neurocranium; kafa; kafatas\u0131; d\xFCzensiz; \u015Fakak; kulak; mastoit;
      \xE7ift"
    body: "\u015Eakak kemi\u011Fidir ve kulaklar\u0131n \xF6n \xFCst b\xF6l\xFCm\xFCnde
      2 adet bulunur."
    steps: "[\"\u0130\xE7inden d\u0131\u015F kulak yolu ge\xE7er.\", \"Kula\u011F\u0131n
      arkas\u0131nda mastoit \xE7\u0131k\u0131nt\u0131s\u0131 vard\u0131r.\", \"Kafan\u0131n
      tek oynar kemi\u011Fi Os Temporale ile Os Mandibula aras\u0131nda bulunur.\"]"
    source: "Ders kitab\u0131 s.54"
  - id: os_mandibula
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Mandibula
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; \xE7ene; alt \xE7ene; d\xFCzensiz; hareketli;
      temporomandibularis; di\u015F"
    body: "Alt \xE7ene kemi\u011Fidir ve Os Temporale ile alt \xE7ene eklemini (art.
      temporomandibularis) olu\u015Fturur. "
    steps: "[\"Y\xFCz b\xF6lgesinin en b\xFCy\xFCk ve en kuvvetli kemi\u011Fidir.\",
      \"\xDCzerinde alt di\u015Flerin s\u0131raland\u0131\u011F\u0131 di\u015F kemeri
      bulunur.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: os_vomer
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Vomer
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; yass\u0131 kemik; burun; sapan"
    body: "Sapan kemi\u011Fidir ve burun b\xF6lmesinin arka alt k\u0131sm\u0131n\u0131
      olu\u015Fturur."
    steps: 
    source: "Ders kitab\u0131 s.55"
  - id: os_maxilla
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Maxilla
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; \xE7ene; \xFCst \xE7ene; d\xFCzensiz; damak;
      di\u015F; \xE7ift"
    body: "\xDCst \xE7ene kemi\u011Fidir ve dama\u011F\u0131n b\xFCy\xFCk b\xF6l\xFCm\xFC
      ile g\xF6z \xE7ukurunun alt k\u0131sm\u0131n\u0131 olu\u015Fturur."
    steps: "[\"2 adet Os Maxilla vard\u0131r.\", \"G\xF6vdesinde 2 adet sin\xFCs
      vard\u0131r.\", \"Alt taraf\u0131nda \xFCst di\u015F kemeri bulunur.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: os_zygomaticum
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Zygomaticum
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; elmac\u0131k; zigomatik; d\xFCzensiz; \xE7ift"
    body: "G\xF6z \xE7ukurunun alt d\u0131\u015F (lateral) b\xF6l\xFCm\xFCnde yer
      al\u0131r. "
    steps: "[\"2 adet Os Zygomaticum vard\u0131r.\", \"Y\xFCzdeki elmac\u0131k t\xFCmse\u011Fini
      olu\u015Fturur.\", \"Sa\u011Flam ve dayan\u0131kl\u0131 bir kemiktir.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: os_nasale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Nasale
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; burun; nazal; yass\u0131 kemik; \xE7ift"
    body: "Burun s\u0131rt\u0131n\u0131n arka b\xF6l\xFCm\xFCn\xFC olu\u015Fturur."
    steps: "[\"2 adet Os Nasale vard\u0131r.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: os_lacrimale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Lacrimale
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; lakrimal; g\xF6zya\u015F\u0131; yass\u0131
      kemik; k\xFC\xE7\xFCk; ince; \xE7ift"
    body: "G\xF6z \xE7ukurunun i\xE7 yan duvar\u0131n\u0131n \xF6n taraf\u0131nda
      yer al\u0131r. "
    steps: "[\"2 adet Os Lacrimale vard\u0131r.\", \"Y\xFCz kemiklerinin en k\xFC\xE7\xFC\u011F\xFC
      ve en incesidir.\", \"\u0130\xE7 tarafta g\xF6zya\u015F\u0131 kanal\u0131 ile
      kom\u015Fudur.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: os_palatinum
    valence: learn
    doc_type: entry
    content_type: bone
    title: Os Palatinum
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; palatin; d\xFCzensiz; \xE7ift; damak"
    body: "\xDCst \xE7ene kemi\u011Fi ile beraber a\u011F\u0131z bo\u015Flu\u011Funun
      tavan\u0131n\u0131 olu\u015Fturur."
    steps: "[\"2 adet Os Palatinum vard\u0131r.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: concha_nasalis_inferior
    valence: learn
    doc_type: entry
    content_type: bone
    title: Concha Nasalis Inferior
    topic: Movement System
    region: Head_Face
    tags: "viscerocranium; kafa; y\xFCz; alt; burun; d\xFCzensiz; \xE7ift; konka"
    body: "Burun bo\u015Flu\u011Funun d\u0131\u015F yan duvar\u0131nda bulunur."
    steps: "[\"2 adet Concha Nasalis Inferior vard\u0131r.\", \"Burun bo\u015Flu\u011Fu
      d\u0131\u015F yan duvar\u0131ndaki 3 konkadan alttakini olu\u015Fturur.\"]"
    source: "Ders kitab\u0131 s.55"
  - id: columna_vertebralis
    valence: learn
    doc_type: entry
    content_type: bone
    title: Columna Vertebralis
    topic: Movement System
    region: Trunk
    tags: "columna vertebralis; omurga; omurga kanal\u0131; lordoz; kifoz; omurilik"
    body: "G\xF6vdenin y\xFCk\xFCn\xFC ta\u015F\u0131yan kemik kolondur. Uzunlu\u011Fu
      eri\u015Fkin bir erkekte yakla\u015F\u0131k 70 cm"
    steps: " kad\u0131nda ise 60 cm\u2019dir. V\xFCcudun dorsal b\xF6lgesinde artkafa
      kemi\u011Finin alt\u0131ndan ba\u015Flay\u0131p pelvise kadar uzan\u0131r.
      Bu kemik kolonda her bir omur deli\u011Finin \xFCst \xFCste gelmesiyle omurga
      kanal\u0131 (canalis vertebralis) olu\u015Fur. Omurgaya yandan bak\u0131ld\u0131\u011F\u0131nda
      d\xF6rt e\u011Frilik g\xF6r\xFCl\xFCr. Bunlar"
    source: " boyun ve bel b\xF6lgesinde lordoz"
  - id: vertebrae_cervicales
    valence: learn
    doc_type: entry
    content_type: bone
    title: Vertebrae cervicales
    topic: Movement System
    region: Trunk
    tags: columna vertebralis; omurga; vertebrae cervicales; omur; vertebra; boyun;
      atlas; axis; lordoz
    body: "7 adet boyun omuru bulunur ve C1-C7 sembolleri ile g\xF6sterilirler. C1
      omura atlas"
    steps: " C2 omura axis ad\u0131 verilir. Atlas \xFCst tarafta foramen magnumu
      \xE7evreleyecek \u015Fekilde artkafa kemi\u011Fi"
    source: ' alt tarafta ise axisle eklem yapar.'
  - id: vertebrae_thoracicae
    valence: learn
    doc_type: entry
    content_type: bone
    title: Vertebrae thoracicae
    topic: Movement System
    region: Trunk
    tags: "columna vertebralis; omurga; vertebrae thoracicae; omur; vertebra; g\xF6\u011F\xFCs;
      kifoz"
    body: "12 adet g\xF6\u011F\xFCs omuru bulunur ve T1-T12 sembolleri ile g\xF6sterilirler.
      Kaburgalarla eklem yaparlar. "
    steps: "[\"Do\u011Fal kifoz e\u011Frili\u011Fi olu\u015Ftururlar.\", \"Hareketleri
      boyun omurlar\u0131na k\u0131yasla daha s\u0131n\u0131rl\u0131d\u0131r.\"]"
    source: "Ders kitab\u0131 s.59"
  - id: vertebrae_lumbales
    valence: learn
    doc_type: entry
    content_type: bone
    title: Vertebrae lumbales
    topic: Movement System
    region: Trunk
    tags: "columna vertebralis; omurga; vertebrae lumbales; omur; vertebra; bel;
      lordoz; b\xFCy\xFCk; sa\u011Flam"
    body: "5 adet bel omuru bulunur ve L1-L5 sembolleri ile g\xF6sterilirler."
    steps: "[\"Do\u011Fal lordoz e\u011Frili\u011Fi olu\u015Ftururlar.\", \"G\xF6vdesi
      en b\xFCy\xFCk ve en sa\u011Flam omurlar lumbal b\xF6lgededir.\", \"V\xFCcut
      a\u011F\u0131rl\u0131\u011F\u0131n\u0131n b\xFCy\xFCk k\u0131sm\u0131n\u0131
      ta\u015F\u0131rlar.\"]"
    source: "Ders kitab\u0131 s.59"
  - id: vertebrae_sacrale
    valence: learn
    doc_type: entry
    content_type: bone
    title: Vertebrae sacrale (os sacrum)
    topic: Movement System
    region: Trunk
    tags: "columna vertebralis; omurga; vertebrae sacrale; os sacrum; omur; vertebra;
      kuyruk sokumu; sa\u011Fr\u0131; promontorium; kifoz; kemik"
    body: "5 adet sa\u011Fr\u0131 omuru bulunur ve S1-S5 sembolleri ile g\xF6sterilirler.
      Bu b\xF6lgedeki omurlar yeti\u015Fkinlerde kayna\u015F\u0131p bir kemi\u011Fe
      d\xF6n\xFC\u015F\xFCr."
    steps: "[\"Do\u011Fal kifoz e\u011Frili\u011Fi olu\u015Ftururlar.\", \"Promontorium
      ad\u0131 verilen \xE7\u0131k\u0131nt\u0131 S1'in g\xF6vdesinin \xFCst kenar\u0131nda
      bulunur.\", \"V\xFCcudun a\u011F\u0131rl\u0131k merkezi S2\u2019nin 2-2,5 cm
      \xF6n\xFCne denk gelir.\"]"
    source: "Ders kitab\u0131 s.59"
  - id: vertebrae_coccygea
    valence: learn
    doc_type: entry
    content_type: bone
    title: Vertebrae coccygea (os coccyge)
    topic: Movement System
    region: Trunk
    tags: columna vertebralis; omurga; vertebrae coccygea; os coccyge; omur; vertebra;
      kuyruk; kemik
    body: "4 adet kuyruk omuru bulunur ve Co1-Co4 sembolleri ile g\xF6sterilirler.
      Bu b\xF6lgedeki omurlar yeti\u015Fkinlerde kayna\u015F\u0131p bir kemi\u011Fe
      d\xF6n\xFC\u015F\xFCr."
    steps: "[\"S5 ile Co1 aras\u0131nda disk yoktur.\"]"
    source: "Ders kitab\u0131 s.59"
  - id: thoracic_cage
    valence: learn
    doc_type: entry
    content_type: bone
    title: "G\xF6\u011F\xFCs kafesi"
    topic: Movement System
    region: Trunk
    tags: "thoracic cage; g\xF6\u011F\xFCs kafesi; g\xF6\u011F\xFCs bo\u015Flu\u011Fu;
      koruma"
    body: "\xD6nde g\xF6\u011F\xFCs tahtas\u0131 kemi\u011Fi (Os Sternum) ile 12
      \xE7ift kaburgadan (Ossa Costae) olu\u015Fur. Arka b\xF6l\xFCm\xFCnde g\xF6\u011F\xFCs"
    steps: 
    source: 
  - id: "omurlar\u0131 bulunur. G\xF6\u011F\xFCs kafesinin i\xE7 k\u0131sm\u0131na
      g\xF6\u011F\xFCs bo\u015Flu\u011Fu denir. Bu bo\u015Flukta kalp ve akci\u011Fer
      gibi \xF6nemli organlar bulunur.;;Ders kitab\u0131 s.60"
    valence: 
    doc_type: 
